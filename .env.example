# ─────────────────────────────────────────────────────────────────────────────
# coldforge configuration — copy to `.env` and fill what you need.
# EVERYTHING here is optional. With an empty file, coldforge still runs:
#   • research  → DuckDuckGo (no key)
#   • draft     → deterministic template fill (no key)
#   • send      → dry-run only until SMTP is configured
# ─────────────────────────────────────────────────────────────────────────────

# --- Personalization (optional) ---------------------------------------------
# Without this, drafts are filled deterministically from the template.
# With it, Claude rewrites the body around the researched signal.
ANTHROPIC_API_KEY=
COLDFORGE_MODEL=claude-haiku-4-5-20251001

# --- Research (optional, all have a free fallback) --------------------------
# Tavily gives much better signal than the default DuckDuckGo scrape.
TAVILY_API_KEY=

# --- Sending (optional — required only to actually send mail) ---------------
# Any SMTP host works (Gmail app password, Fastmail, Postmark, etc.)
COLDFORGE_FROM_NAME=Your Name
COLDFORGE_FROM_EMAIL=you@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true

# --- Reply detection (optional — enables auto-cancel of follow-ups) ---------
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# --- Safe-send guardrails ----------------------------------------------------
COLDFORGE_DAILY_LIMIT=40          # max sends per day per account
COLDFORGE_SEND_WINDOW=09:00-17:00 # local-time window; outside it, tick sends nothing
COLDFORGE_SEND_DAYS=mon-fri       # weekdays only by default
COLDFORGE_MIN_GAP_SECONDS=45      # jittered minimum gap between two sends

# --- Storage (optional) ------------------------------------------------------
# Defaults to ~/.coldforge/coldforge.db ; set to keep state next to a project.
COLDFORGE_HOME=
